APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_DATABASE_ID=your_database_id_here
APPWRITE_COLLECTION_ID=avatars
APPWRITE_BUCKET_ID=your_bucket_id_here
APPWRITE_API_KEY=your_api_key_here

RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
CACHE_TTL_SUCCESS=3600
CACHE_TTL_ERROR=300
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30000
LOG_LEVEL=info

# Cloudflare Vectorize Configuration
VECTORIZE_INDEX_NAME=avatar-embeddings

# Image Generation Service URL 
IMAGE_SERVICE_URL=YOUR_IMAGE_SERVICE_URL
IMAGE_SERVICE_KEY=YOUR_IMAGE_SERVICE_KEY

# Vector search 
VECTOR_SEARCH_LIMIT=10
VECTOR_SEARCH_THRESHOLD=0.7
VECTOR_SEARCH_INCLUDE_METADATA=true